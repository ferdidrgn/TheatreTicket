<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.ferdidrgn.theatreticket.ui.login.LoginViewModel" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/main_dark2"
        android:gravity="center"
        tools:context=".ui.login.LoginActivity">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_border_google_sign_in">

            <com.ferdidrgn.theatreticket.tools.components.CustomButton
                android:id="@+id/btnSignIn"
                android:layout_width="67dp"
                android:layout_height="52dp"
                android:text="@string/sign_up_google"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:cst_btn_endIcon="@drawable/googleg_standard_color_18"
                app:cst_btn_endIcon_visibility="true"
                app:cst_btn_name="@string/i_read_and_agree" />

        </LinearLayout>


    </LinearLayout>


</layout>