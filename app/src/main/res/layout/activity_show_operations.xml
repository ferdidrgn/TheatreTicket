<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.ferdidrgn.theatreticket.ui.showOperations.ShowOperationsViewModel" />

        <variable
            name="showOperationsAdapter"
            type="com.ferdidrgn.theatreticket.ui.showOperations.ShowOperationsAdapter" />
    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".ui.showOperations.ShowOperationsActivity">

        <com.ferdidrgn.theatreticket.tools.components.CustomToolbar
            android:id="@+id/customToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            app:cst_toolbar_backIcon_visible="true"
            app:cst_toolbar_text="@string/show_operations" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvShowAll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_above="@+id/btnAddShow"
            android:layout_below="@+id/customToolbar"
            android:overScrollMode="never"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_behavior="@string/appbar_scrolling_view_behavior"
            app:layout_constraintBottom_toTopOf="@id/btnAddShow"
            app:setAdapter="@{showOperationsAdapter}"
            app:submitList="@{viewModel.show}"
            tools:listitem="@layout/item_show_operations" />

        <com.ferdidrgn.theatreticket.tools.components.CustomButton
            android:id="@+id/btnAddShow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:onClick="@{()->viewModel.onBtnAddShow()}"
            app:cst_button_name="@string/show_add" />

    </RelativeLayout>
</layout>