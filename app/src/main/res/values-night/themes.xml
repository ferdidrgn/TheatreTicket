<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TheatreTicket" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:navigationBarColor">?attr/colorPrimary</item>
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Primary Color -->
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/dark2</item>
        <item name="colorOnPrimary">@color/dark3</item>
        <item name="colorPrimaryFixed">@color/dark4</item>
        <item name="colorOnPrimarySurface">@color/dark5</item>

        <!-- Secondary Color -->
        <item name="colorSecondary">@color/dark6</item>
        <item name="colorSecondaryVariant">@color/dark7</item>
        <item name="colorOnSecondary">@color/white_light</item>
        <item name="colorOnSecondaryFixed">@color/pink_light</item>

        <!-- Background Color -->
        <item name="colorSurface">@color/pink_success</item>
        <item name="colorOnSurface">@color/red_err</item>
        <item name="colorOnSurfaceVariant">@color/red</item>
        <item name="colorOnSurfaceInverse">@color/green_light</item>
        <item name="colorOnTertiary">@color/blue_light</item>

    </style>

    <!-- Customize style -->
    <style name="ScreenBackgroun">
        <item name="android:background">@color/black</item>
    </style>

    <style name="CardBackground">
        <item name="android:background">@color/black</item>
    </style>

    <style name="TextColor">
        <item name="android:background">@color/dark7</item>
    </style>

    <style name="rounded_main_dark_border_main">
        <item name="android:src">@drawable/bg_primary2_border_primary3</item>
    </style>
</resources>