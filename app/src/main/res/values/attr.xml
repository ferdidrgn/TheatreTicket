<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="CustomEditText">
        <attr name="custom_edit_hint" format="string" />
        <attr name="custom_edit_input" format="integer" />
    </declare-styleable>

    <declare-styleable name="CustomButton">
        <attr name="cst_button_name" format="string" />
        <attr name="cst_buttonColor" format="integer" />
        <attr name="cst_backgroundColorFromXml" format="color" />
    </declare-styleable>

    <declare-styleable name="custom_toolbar">
        <attr name="cst_toolbar_closeIcon_visible" format="boolean" />
        <attr name="cst_toolbar_backIcon_visible" format="boolean" />
        <attr name="cst_toolbar_text" format="string" />
        <attr name="customToolBarChangeableText" format="string" />
    </declare-styleable>

</resources>