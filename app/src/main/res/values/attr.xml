<?xml version="1.0" encoding="utf-8"?>
<resources>

    <declare-styleable name="CustomEditText">
        <attr name="custom_edit_hint" format="string" />
        <attr name="custom_edit_input" format="integer" />
    </declare-styleable>

    <declare-styleable name="CustomButton">
        <attr name="button_name" format="string" />
        <attr name="buttonColor" format="integer" />
        <attr name="backgroundColorFromXml" format="color" />
    </declare-styleable>

    <declare-styleable name="custom_toolbar">
        <attr name="closeIcon_visible" format="boolean" />
        <attr name="backIcon_visible" format="boolean" />
        <attr name="cst_text" format="string" />
        <attr name="customToolBarChangeableText" format="string" />
    </declare-styleable>

</resources>