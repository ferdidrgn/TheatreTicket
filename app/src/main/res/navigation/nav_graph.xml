<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.ferdidrgn.theatreticket.ui.main.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_ticket_buy"
        android:name="com.ferdidrgn.theatreticket.ui.main.ticketBuy.TicketBuyFragment"
        android:label="@string/ticket_buy"
        tools:layout="@layout/fragment_ticket_buy" />

    <fragment
        android:id="@+id/navigation_ticket_search"
        android:name="com.ferdidrgn.theatreticket.ui.main.ticketSearch.TicketSearchFragment"
        android:label="@string/ticket_search"
        tools:layout="@layout/fragment_ticket_search" />

    <fragment
        android:id="@+id/navigation_settings_fragment"
        android:name="com.ferdidrgn.theatreticket.ui.main.settings.SettingsFragment"
        android:label="@string/settings"
        tools:layout="@layout/fragment_settings" >
        <action
            android:id="@+id/action_navigation_settings_fragment_to_navigation_ticket_buy"
            app:destination="@id/navigation_ticket_buy" />
    </fragment>
</navigation>