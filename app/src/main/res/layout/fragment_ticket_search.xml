<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.ferdidrgn.theatreticket.ui.main.ticketSearch.TicketSearchViewModel" />
    </data>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="20dp"
            android:orientation="vertical"
            tools:context=".ui.main.ticketBuy.TicketSearchFragment">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginVertical="10dp"
                android:layout_marginStart="10dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:weightSum="2">

                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.ferdidrgn.theatreticket.tools.components.CustomEditText
                        android:id="@+id/etPhoneNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true"
                        android:layout_marginTop="5dp"
                        android:textAlignment="textStart"
                        app:custom_edit_hint="@string/phone_number_mask"
                        app:custom_edit_input="1"
                        app:custom_edit_text="@={viewModel.phoneNumber}" />

                    <com.ferdidrgn.theatreticket.tools.components.CustomEditText
                        android:id="@+id/etFirstName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/etPhoneNumber"
                        android:layout_alignEnd="@+id/etPhoneNumber"
                        android:layout_alignParentStart="true"
                        android:layout_marginTop="5dp"
                        android:textAlignment="textStart"
                        app:custom_edit_hint="@string/first_name"
                        app:custom_edit_input="1"
                        app:custom_edit_text="@{viewModel.firstName}" />

                    <com.ferdidrgn.theatreticket.tools.components.CustomEditText
                        android:id="@+id/etLastName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/etFirstName"
                        android:layout_alignEnd="@+id/etFirstName"
                        android:layout_alignParentStart="true"
                        android:layout_marginTop="5dp"
                        android:textAlignment="textStart"
                        app:custom_edit_hint="@string/last_name"
                        app:custom_edit_input="1"
                        app:custom_edit_text="@{viewModel.lastName}" />

                </RelativeLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1">

                    <com.ferdidrgn.theatreticket.tools.components.CustomButton
                        android:id="@+id/btnSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="15dp"
                        android:onClick="@{()->viewModel.searchTicket()}"
                        app:button_name="@string/search_for_buy_ticket" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="10dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/choose_seats"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone_number_mask"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/first_name"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/last_name"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="50dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/game_date"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stage_name"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stage_location"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_thirth"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_chooseSeats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="A18, A20" />

                    <TextView
                        android:id="@+id/tv_phoneNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="@string/phone_number_mask" />

                    <TextView
                        android:id="@+id/tv_firstName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="@string/first_name" />

                    <TextView
                        android:id="@+id/tv_lastName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="@string/last_name" />

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="50dp" />

                    <TextView
                        android:id="@+id/tv_gameDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="@string/game_date" />

                    <TextView
                        android:id="@+id/tv_stageName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="@string/stage_name" />

                    <TextView
                        android:id="@+id/tv_stageLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAlignment="textStart"
                        android:textColor="@color/main_fifth"
                        android:textSize="18sp"
                        tools:text="@string/stage_location" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</layout>