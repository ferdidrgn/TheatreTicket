<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <!-- Customize your light theme here. -->
    <style name="Theme.TheatreTicket" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:navigationBarColor">?attr/colorPrimary</item>
        <item name="android:windowBackground">@drawable/splash_screen</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Primary Color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary2</item>
        <item name="colorOnPrimary">@color/primary3</item>
        <item name="colorPrimaryFixed">@color/primary4</item>
        <item name="colorOnPrimarySurface">@color/primary5</item>

        <!-- Secondary Color -->
        <item name="colorSecondary">@color/primary6</item>
        <item name="colorSecondaryVariant">@color/primary7</item>
        <item name="colorOnSecondary">@color/white_light</item>
        <item name="colorOnSecondaryFixed">@color/pink_light</item>

        <!-- Background Color -->
        <item name="colorSurface">@color/pink_success</item>
        <item name="colorOnSurface">@color/red_err</item>
        <item name="colorOnSurfaceVariant">@color/red</item>
        <item name="colorOnSurfaceInverse">@color/green_light</item>
        <item name="colorOnTertiary">@color/blue_light</item>

    </style>

    <!-- Customize style -->
    <style name="ScreenBackgroun">
        <item name="android:background">@color/primary</item>
    </style>

    <style name="CardBackground">
        <item name="android:background">@color/primary</item>
    </style>

    <style name="TextColor">
        <item name="android:textColor">@color/primary7</item>
    </style>

    <style name="ImageTintColor">
        <item name="android:tint">@color/pink_light</item>
    </style>

    <style name="rounded_primary2_10_border_primary3">
        <item name="android:background">@drawable/bg_dark2_10_border_dark3</item>
    </style>



    <style name="DialogTheme_transparent" parent="Theme.AppCompat.Dialog">
        <item name="android:windowBackground">
            @drawable/rounded_border_main_1_dp_radius_10_transparent
        </item>
        <!--You can set other style items also, such as animations and etc-->
    </style>

    <style name="bottomSheetDialog" parent="bottomSheetDialog.Base" />

    <style name="bottomSheetDialog.Base" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="android:windowSoftInputMode">stateAlwaysHidden|adjustResize</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowCloseOnTouchOutside">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:colorBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:backgroundDimAmount">0.0</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowFrame">@null</item>
        <item name="behavior_draggable">false</item>
    </style>

    <style name="ImageView.SquareBorder" parent="">
        <item name="cornerSize">8%</item>
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="ShapeAppearanceOverlay.Corner20DP" parent="">
        <item name="cornerSize">20dp</item>
        <item name="cornerFamily">rounded</item>
    </style>
</resources>